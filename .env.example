# LiqHawk frontend — template environment file.
# Copy to `.env` and adjust for your setup. Only variables prefixed with
# VITE_ are exposed to the browser bundle (Vite convention).

# Base URL of the FastAPI backend. The frontend prepends this to every API path.
# Leave blank to use same-origin (e.g., when the SPA is served from FastAPI itself).
VITE_API_BASE=http://localhost:8000